# Backend API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# For production, set to:
# NEXT_PUBLIC_API_BASE_URL=https://api.thecodexai.com

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_WAITLIST=true
NEXT_PUBLIC_ENABLE_LAB=true
NEXT_PUBLIC_ENABLE_COMMISSIONED_WORKS=false

# Email Configuration (for waitlist notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@thecodexai.com
